<div class="article-wrapper">
    <%
        const colorConfig = theme.colors || [];
        const legacyColors = Array.isArray(colorConfig) ? colorConfig : [];
        const lightColorPool =
            !Array.isArray(colorConfig) && Array.isArray(colorConfig.light) && colorConfig.light.length !== 0
                ? colorConfig.light
                : legacyColors;
        const darkColorPool =
            !Array.isArray(colorConfig) && Array.isArray(colorConfig.dark) && colorConfig.dark.length !== 0
                ? colorConfig.dark
                : lightColorPool;

        const pickColor = (pool, prev, fallback) => {
            const choices = pool.filter((color) => color !== prev);
            if (choices.length !== 0) return choices[Math.floor(Math.random() * choices.length)];
            if (pool.length !== 0) return pool[Math.floor(Math.random() * pool.length)];
            return fallback;
        };
    %>
    <% if (theme.toc && typeof theme.toc.enable !== 'undefined' ? theme.toc.enable : true) { %>
    <div id="toc-container" class="toc-container">
        <div class="toc-header">
            <span class="toc-title">文章目录</span>
            <button class="toc-toggle" id="toc-toggle" title="展开/收起目录">
                <i class="fa-solid fa-chevron-up"></i>
            </button>
        </div>
        <nav id="toc" class="toc"></nav>
    </div>
    <% } %>
    <div class="article">
        <div>
            <h1><%= page.title %></h1>
        </div>
        <div class="info">
            <span class="date">
                <span class="icon">
                    <i class="fa-solid fa-calendar fa-fw"></i>
                </span>
                <%= date(page.date, "YYYY/M/D") %>
            </span>
            <% const readingTime = page.readTime || page.readtime; %>
            <% if (typeof readingTime !== "undefined" && readingTime) { %>
            <span class="date">
                <span class="icon">
                    <i class="fa-solid fa-clock fa-fw"></i>
                </span>
                <%= readingTime %>
            </span>
            <% } %>
            <% if (page.categories && page.categories.data.length !== 0) { %>
            <span class="category">
                <a href="<%- url_for(page.categories.data[0].path) %>">
                    <span class="icon">
                        <i class="fa-solid fa-bookmark fa-fw"></i>
                    </span>
                    <%= page.categories.data[0].name %>
                </a>
            </span>
            <% } %>
            <% if (page.tags && page.tags.data.length !== 0) { %>
            <span class="tags">
                <span class="icon">
                    <i class="fa-solid fa-tags fa-fw"></i>
                </span>
                <% let prevLight; %>
                <% let prevDark; %>
                <% page.tags.data.forEach((tag) => { %>
                <span class="tag">
                    <%
                        const lightColor = pickColor(lightColorPool, prevLight, "#5c6b72");
                        const darkColor = pickColor(darkColorPool, prevDark, lightColor);
                        prevLight = lightColor;
                        prevDark = darkColor;
                    %>
                    <a
                        href="<%- url_for(tag.path) %>"
                        style="--tag-color-light: <%- lightColor %>; --tag-color-dark: <%- darkColor %>; color: var(--tag-color-light)"
                    >
                        <%= tag.name %>
                    </a>
                </span>
                <% }); %>
            </span>
            <% } %>
        </div>
        <% if (theme.crypto.enable && typeof page.secret !== "undefined") { %>
        <% const CryptoJS = getCryptoJS(); %>
        <input
            id="crypto"
            :class="['input', cryptoStatus]"
            :disabled="cryptoStatus === 'success'"
            ref="crypto"
            placeholder="文章被加密，请输入密码"
            data-encrypted="<%- CryptoJS.AES.encrypt(page.content, page.secret).toString() %>"
            data-shasum="<%- CryptoJS.SHA256(page.content).toString() %>"
            v-model="crypto"
        />
        <transition name="fade">
            <div class="content" ref="content" v-show="cryptoStatus === 'success'"></div>
        </transition>
        <% } else { %>
        <div class="content" v-pre>
            <%- page.content %>
        </div>
        <% } %>
        <% if (page.comments) { %>
        <% if (theme.gitalk.enable) { %>
        <div id="comment">
            <div id="gitalk-container"></div>
        </div>
        <% } %>
        <% if (theme.giscus.enable) { %>
        <div id="comment">
            <div id="giscus-container" class="giscus"></div>
        </div>
        <% } %>
        <% if (theme.waline.enable) { %>
        <div id="comment">
            <div id="waline-container"></div>
        </div>
        <% } %>
        <% if (theme.twikoo.enable) { %>
        <div id="comment">
            <div id="twikoo-container"></div>
        </div>
        <% } %>
        <% } %>
    </div>
</div>
