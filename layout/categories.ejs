<div id="archives">
    <% let posts = []; %>
    <%
        const colorConfig = theme.colors || [];
        const legacyColors = Array.isArray(colorConfig) ? colorConfig : [];
        const lightColorPool =
            !Array.isArray(colorConfig) && Array.isArray(colorConfig.light) && colorConfig.light.length !== 0
                ? colorConfig.light
                : legacyColors;
        const darkColorPool =
            !Array.isArray(colorConfig) && Array.isArray(colorConfig.dark) && colorConfig.dark.length !== 0
                ? colorConfig.dark
                : lightColorPool;

        const pickColor = (pool, prev, fallback) => {
            const choices = pool.filter((color) => color !== prev);
            if (choices.length !== 0) return choices[Math.floor(Math.random() * choices.length)];
            if (pool.length !== 0) return pool[Math.floor(Math.random() * pool.length)];
            return fallback;
        };
    %>
    <div class="categories-tags">
        <% let prevLight; %>
        <% let prevDark; %>
        <% site.categories.forEach((category) => { %>
        <%
            const lightColor = is_category(category.name)
                ? "linear-gradient(120deg, #9abbf7 0%, #ffbbf4 100%)"
                : pickColor(lightColorPool, prevLight, "#7d90a7");
            const darkColor = is_category(category.name)
                ? "linear-gradient(120deg, #6f89c8 0%, #c58ec3 100%)"
                : pickColor(darkColorPool, prevDark, lightColor);
            prevLight = lightColor;
            prevDark = darkColor;
        %>
        <span>
            <a
                href="<%- url_for(category.path) %>"
                style="--tag-color-light: <%- lightColor %>; --tag-color-dark: <%- darkColor %>; background: var(--tag-color-light)"
            >
                <span class="icon">
                    <i class="fa-solid fa-bookmark fa-fw"></i>
                </span>
                <%= category.name %>
            </a>
        </span>
        <% if (is_category(category.name)) { %>
        <%
            posts = category.posts;
            posts.data.sort((a, b) => b.date - a.date);
        %>
        <% } %>
        <% }); %>
    </div>
    <% posts.forEach((post) => { %>
    <div class="timeline">
        <div class="timeline-tail"></div>
        <div class="timeline-content">
            <div class="item-time"><%= date(post.date, "YYYY/M/D") %></div>
            <a href="<%- url_for(post.path) %>">
                <h3><%= post.title %></h3>
            </a>
            <div class="info">
                <% if (post.categories && post.categories.data.length !== 0) { %>
                <span class="category">
                    <a href="<%- url_for(post.categories.data[0].path) %>">
                        <span class="icon">
                            <i class="fa-solid fa-bookmark fa-fw"></i>
                        </span>
                        <%= post.categories.data[0].name %>
                    </a>
                </span>
                <% } %>
                <% if (post.tags && post.tags.data.length !== 0) { %>
                <span class="tags">
                    <span class="icon">
                        <i class="fa-solid fa-tags fa-fw"></i>
                    </span>
                    <% let prevLight; %>
                    <% let prevDark; %>
                    <% post.tags.data.forEach((tag) => { %>
                    <span class="tag">
                        <%
                            const lightColor = pickColor(lightColorPool, prevLight, "#5c6b72");
                            const darkColor = pickColor(darkColorPool, prevDark, lightColor);
                            prevLight = lightColor;
                            prevDark = darkColor;
                        %>
                        <a
                            href="<%- url_for(tag.path) %>"
                            style="--tag-color-light: <%- lightColor %>; --tag-color-dark: <%- darkColor %>; color: var(--tag-color-light)"
                        >
                            <%= tag.name %>
                        </a>
                    </span>
                    <% }); %>
                </span>
                <% } %>
            </div>
        </div>
    </div>
    <% }); %>
</div>
