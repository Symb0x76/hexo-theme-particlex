<%
    // Prefer page.posts (generated by hexo-generator-archive) so yearly/monthly archive pages
    // only render posts in that range.
    let posts = (page.posts && page.posts.data) ? page.posts.data.slice() : site.posts.data.slice();
    const colorConfig = theme.colors || [];
    const legacyColors = Array.isArray(colorConfig) ? colorConfig : [];
    const lightColorPool =
        !Array.isArray(colorConfig) && Array.isArray(colorConfig.light) && colorConfig.light.length !== 0
            ? colorConfig.light
            : legacyColors;
    const darkColorPool =
        !Array.isArray(colorConfig) && Array.isArray(colorConfig.dark) && colorConfig.dark.length !== 0
            ? colorConfig.dark
            : lightColorPool;

    const pickColor = (pool, prev, fallback) => {
        const choices = pool.filter((color) => color !== prev);
        if (choices.length !== 0) return choices[Math.floor(Math.random() * choices.length)];
        if (pool.length !== 0) return pool[Math.floor(Math.random() * pool.length)];
        return fallback;
    };

    posts.sort((a, b) => b.date - a.date);

    // Build year/month navigation from all posts
    const allPosts = site.posts.data.slice().sort((a, b) => b.date - a.date);
    const yearToMonths = {};
    allPosts.forEach((post) => {
        const y = date(post.date, 'YYYY');
        const m = date(post.date, 'MM');
        if (!yearToMonths[y]) yearToMonths[y] = new Set();
        yearToMonths[y].add(m);
    });
    const years = Object.keys(yearToMonths).sort((a, b) => Number(b) - Number(a));
    const currentYear = typeof page.year !== 'undefined' ? String(page.year) : null;
    const currentMonth = typeof page.month !== 'undefined' ? String(page.month).padStart(2, '0') : null;
    const monthsOfCurrentYear = currentYear && yearToMonths[currentYear]
        ? Array.from(yearToMonths[currentYear]).sort((a, b) => Number(b) - Number(a))
        : [];
%>
<div id="archives">
    <% if (theme.search.enable) { %>
    <input id="search-bar" class="input" placeholder="搜索" v-model="rawSearch" />
    <% } %>

    <div class="categories-tags">
        <% if (currentYear) { %>
        <span>
            <a href="<%- url_for('/archives/') %>">
                <span class="icon"><i class="fa-solid fa-clock-rotate-left fa-fw"></i></span>
                全部
            </a>
        </span>
        <span>
            <a href="<%- url_for('/archives/' + currentYear + '/') %>">
                <span class="icon"><i class="fa-solid fa-calendar fa-fw"></i></span>
                <%= currentYear %>
            </a>
        </span>
        <% monthsOfCurrentYear.forEach((m) => { %>
        <span>
            <a href="<%- url_for('/archives/' + currentYear + '/' + m + '/') %>" style="<%- currentMonth === m ? 'background:#fff;border:#a5c2f5 1px solid;color:#5c6b72' : '' %>">
                <span class="icon"><i class="fa-solid fa-calendar-days fa-fw"></i></span>
                <%= m %>
            </a>
        </span>
        <% }); %>
        <% } else { %>
        <% years.forEach((y) => { %>
        <span>
            <a href="<%- url_for('/archives/' + y + '/') %>">
                <span class="icon"><i class="fa-solid fa-calendar fa-fw"></i></span>
                <%= y %>
            </a>
        </span>
        <% }); %>
        <% } %>
    </div>

    <div id="timeline-wrap" ref="timeline">
        <% posts.reverse().forEach((post, id) => { %>
        <%
            const searchCategories = post.categories && post.categories.data
                ? post.categories.data.map((c) => c.name).join(" ")
                : "";
            const searchTags = post.tags && post.tags.data
                ? post.tags.data.map((t) => t.name).join(" ")
                : "";
            const searchContent = strip_html(post.content || "");
            const searchText = [
                post.title || "",
                searchCategories,
                searchTags,
                searchContent,
            ]
                .join(" ")
                .toLowerCase()
                .replace(/\s+/g, "");
        %>
        <div class="timeline" data-search="<%- encodeURIComponent(searchText) %>">
            <div class="timeline-tail"></div>
            <div class="timeline-content">
                <div class="item-time"><%= date(post.date, "YYYY/M/D") %></div>
                <a href="<%- url_for(post.path) %>">
                    <h3><%= post.title %></h3>
                </a>
                <div class="info">
                    <% if (post.categories && post.categories.data.length !== 0) { %>
                    <span class="category">
                        <a href="<%- url_for(post.categories.data[0].path) %>">
                            <span class="icon">
                                <i class="fa-solid fa-bookmark fa-fw"></i>
                            </span>
                            <%= post.categories.data[0].name %>
                        </a>
                    </span>
                    <% } %>
                    <% if (post.tags && post.tags.data.length !== 0) { %>
                    <span class="tags">
                        <span class="icon">
                            <i class="fa-solid fa-tags fa-fw"></i>
                        </span>
                        <% let prevLight; %>
                        <% let prevDark; %>
                        <% post.tags.data.forEach((tag) => { %>
                        <span class="tag">
                            <%
                                const lightColor = pickColor(lightColorPool, prevLight, "#5c6b72");
                                const darkColor = pickColor(darkColorPool, prevDark, lightColor);
                                prevLight = lightColor;
                                prevDark = darkColor;
                            %>
                            <a
                                href="<%- url_for(tag.path) %>"
                                style="--tag-color-light: <%- lightColor %>; --tag-color-dark: <%- darkColor %>; color: var(--tag-color-light)"
                            >
                                <%= tag.name %>
                            </a>
                        </span>
                        <% }); %>
                    </span>
                    <% } %>
                </div>
            </div>
        </div>
        <% }); %>
    </div>
</div>
